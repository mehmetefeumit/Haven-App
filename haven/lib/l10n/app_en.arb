  "onboardingValueProp1Title": "Only your circles can see you",
  "@onboardingValueProp1Title": {
    "description": "Headline of the first onboarding value-prop card (also reused on the About page)."
  },
  "onboardingValueProp1Body": "Your location is encrypted on your device before it leaves, so only the circles you choose can read it, never Haven or anyone else. Because Haven is open source, anyone can verify that.",
  "@onboardingValueProp1Body": {
    "description": "Body of the first onboarding value-prop card (also reused on the About page)."
  },
  "onboardingValueProp2Title": "No one can shut it down",
  "@onboardingValueProp2Title": {
    "description": "Headline of the second onboarding value-prop card (also reused on the About page)."
  },
  "onboardingValueProp2Body": "Haven has no central server. Your encrypted messages travel through a decentralized network of relays that you can choose yourself, so no single entity can shut it down.",
  "@onboardingValueProp2Body": {
    "description": "Body of the second onboarding value-prop card (also reused on the About page)."
  },
  "onboardingValueProp3Title": "No account needed",
  "@onboardingValueProp3Title": {
    "description": "Headline of the third onboarding value-prop card (also reused on the About page)."
  },
  "onboardingValueProp3Body": "No email, no phone number, no sign-up. Haven creates a private identity that lives only on your phone, with nothing linking it to the real you.",
  "@onboardingValueProp3Body": {
    "description": "Body of the third onboarding value-prop card (also reused on the About page)."
  },
  "onboardingValueProp1Summary": "Encrypted on your device, so only the circles you choose can read it.",
